# OpenCLIP Inference API — Environment Variables

# Model configuration
MODEL_NAME=ViT-B-32
PRETRAINED=openai
DEVICE=auto

# API settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
LOG_LEVEL=info

# Redis (caching)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=86400

# Celery (batch processing)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Batch settings
MAX_BATCH_SIZE=64
